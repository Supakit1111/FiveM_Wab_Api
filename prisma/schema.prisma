generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int                    @id @default(autoincrement())
  inGameName       String                 @map("in_game_name")
  phoneNumber      String                 @unique @map("phone_number")
  password         String
  role             String                 @default("USER")
  profileImageUrl  String?                @map("profile_image_url")
  money            Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  attendances      AttendanceLog[]
  gangTransactions GangTransaction[]
  transactions     InventoryTransaction[]

  @@map("users")
}

model AttendanceLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  checkInTime DateTime @default(now()) @map("check_in_time")
  session     Int      @default(1)
  status      String   @default("O")
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, checkInTime])
  @@map("attendance_logs")
}

model Item {
  id           Int                    @id @default(autoincrement())
  name         String                 @unique
  currentStock Int                    @map("current_stock")
  lastUpdated  DateTime               @default(now()) @map("last_updated")
  transactions InventoryTransaction[]

  @@map("items")
}

model InventoryTransaction {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  itemId          Int      @map("item_id")
  quantity        Int
  transactionType String
  reason          String?
  timestamp       DateTime @default(now())
  item            Item     @relation(fields: [itemId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@map("inventory_transactions")
}

model ActionLog {
  id          Int      @id @default(autoincrement())
  performerId Int      @map("performer_id")
  actionType  String
  details     String
  timestamp   DateTime @default(now())

  @@map("action_logs")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  status    String   @default("ACTIVE")
  priority  String   @default("NORMAL")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model GlobalSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("global_settings")
}

model GangTransaction {
  id            Int      @id @default(autoincrement())
  type          String
  amount        Int
  description   String
  balanceBefore Int      @map("balance_before")
  balanceAfter  Int      @map("balance_after")
  createdById   Int      @map("created_by_id")
  createdAt     DateTime @default(now())
  createdBy     User     @relation(fields: [createdById], references: [id])

  @@map("gang_transactions")
}
